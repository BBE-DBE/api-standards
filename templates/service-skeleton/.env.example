# __SERVICE_NAME__ — environment template.
# Copy to .env and fill values. Never commit .env.

NODE_ENV=production
PORT=__DEFAULT_PORT__
HOST=127.0.0.1
LOG_LEVEL=info

# Database (must match a service-user provisioned in infra-postgres).
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=__DB_SCHEMA___svc
PGPASSWORD=replace_me
PGDATABASE=ecosystem
PG_SCHEMA=__DB_SCHEMA__
PG_POOL_MAX=20
PG_POOL_MIN=2
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=10000
