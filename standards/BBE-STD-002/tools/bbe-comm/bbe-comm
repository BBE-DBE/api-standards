#!/usr/bin/env python3
"""bbe-comm CLI shim — runs the bbe_comm package's `cli.main`.

Install at /usr/local/bin/bbe-comm OR symlink. The shim resolves the
sibling `bbe_comm/` package and runs it with the system Python 3.
"""
import sys
from pathlib import Path

# Ensure the sibling package is importable when this shim is run from any cwd.
_HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(_HERE))

from bbe_comm.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
